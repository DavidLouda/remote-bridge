{
  "name": "remote-bridge",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "3.4.0",
  "publisher": "DavidLouda",
  "author": {
    "name": "David Louda"
  },
  "license": "MIT",
  "icon": "resources/Logo.png",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ssh",
    "sftp",
    "ftp",
    "remote",
    "file system",
    "remote development",
    "copilot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DavidLouda/remote-bridge"
  },
  "pricing": "Free",
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onFileSystem:remote-bridge",
    "onChatParticipant:remote-bridge.bridge"
  ],
  "contributes": {
    "resourceLabelFormatters": [
      {
        "scheme": "remote-bridge",
        "formatting": {
          "label": "${path}",
          "separator": "/",
          "workspaceSuffix": "Remote Bridge"
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "remote-bridge",
          "title": "%viewContainer.title%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "remote-bridge": [
        {
          "id": "remoteBridge.connections",
          "name": "%view.connections.name%",
          "icon": "$(server)"
        },
        {
          "id": "remoteBridge.activeSessions",
          "name": "%view.activeSessions.name%",
          "icon": "$(plug)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "remoteBridge.connections",
        "contents": "%welcome.noConnections%",
        "when": "!remoteBridge.encryptionEnabled || remoteBridge.encryptionUnlocked"
      },
      {
        "view": "remoteBridge.connections",
        "contents": "%welcome.connectionsLocked%",
        "when": "remoteBridge.encryptionEnabled && !remoteBridge.encryptionUnlocked"
      }
    ],
    "commands": [
      {
        "command": "remoteBridge.addConnection",
        "title": "%command.addConnection.title%",
        "icon": "$(add)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.editConnection",
        "title": "%command.editConnection.title%",
        "icon": "$(edit)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.deleteConnection",
        "title": "%command.deleteConnection.title%",
        "icon": "$(trash)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.connect",
        "title": "%command.connect.title%",
        "icon": "$(plug)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.disconnect",
        "title": "%command.disconnect.title%",
        "icon": "$(debug-disconnect)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.openWorkspace",
        "title": "%command.openWorkspace.title%",
        "icon": "$(folder-opened)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.openTerminal",
        "title": "%command.openTerminal.title%",
        "icon": "$(terminal)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.addFolder",
        "title": "%command.addFolder.title%",
        "icon": "$(new-folder)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.renameFolder",
        "title": "%command.renameFolder.title%",
        "icon": "$(edit)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.deleteFolder",
        "title": "%command.deleteFolder.title%",
        "icon": "$(trash)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.importSSH",
        "title": "%command.importSSH.title%",
        "icon": "$(key)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.importWinSCP",
        "title": "%command.importWinSCP.title%",
        "icon": "$(desktop-download)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.importSSHFS",
        "title": "%command.importSSHFS.title%",
        "icon": "$(extensions)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.importFileZilla",
        "title": "%command.importFileZilla.title%",
        "icon": "$(cloud-download)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.importPuTTY",
        "title": "%command.importPuTTY.title%",
        "icon": "$(terminal)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.importTotalCmd",
        "title": "%command.importTotalCmd.title%",
        "icon": "$(folder)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.setMasterPassword",
        "title": "%command.setMasterPassword.title%",
        "icon": "$(lock)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.changeMasterPassword",
        "title": "%command.changeMasterPassword.title%",
        "icon": "$(key)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.unlockMasterPassword",
        "title": "%command.unlockMasterPassword.title%",
        "icon": "$(unlock)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.lockMasterPassword",
        "title": "%command.lockMasterPassword.title%",
        "icon": "$(lock)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.removeMasterPassword",
        "title": "%command.removeMasterPassword.title%",
        "icon": "$(trash)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.restoreBackup",
        "title": "%command.restoreBackup.title%",
        "icon": "$(history)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.createBackup",
        "title": "%command.createBackup.title%",
        "icon": "$(archive)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.duplicateConnection",
        "title": "%command.duplicateConnection.title%",
        "icon": "$(copy)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.moveToFolder",
        "title": "%command.moveToFolder.title%",
        "icon": "$(folder-opened)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.import",
        "title": "%command.import.title%",
        "icon": "$(cloud-download)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.exportConnections",
        "title": "%command.exportConnections.title%",
        "icon": "$(cloud-upload)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.syncNow",
        "title": "%command.syncNow.title%",
        "icon": "$(sync)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.showConnections",
        "title": "%command.showConnections.title%",
        "icon": "$(plug)",
        "category": "Remote Bridge"
      },
      {
        "command": "remoteBridge.changePermissions",
        "title": "%command.changePermissions.title%",
        "icon": "$(shield)",
        "category": "Remote Bridge"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "remoteBridge.addConnection",
          "when": "view == remoteBridge.connections",
          "group": "navigation@1"
        },
        {
          "command": "remoteBridge.addFolder",
          "when": "view == remoteBridge.connections",
          "group": "navigation@2"
        },
        {
          "command": "remoteBridge.refresh",
          "when": "view == remoteBridge.connections",
          "group": "navigation@3"
        },
        {
          "command": "remoteBridge.import",
          "when": "view == remoteBridge.connections",
          "group": "overflow@1"
        },
        {
          "command": "remoteBridge.exportConnections",
          "when": "view == remoteBridge.connections",
          "group": "overflow@2"
        },
        {
          "command": "remoteBridge.syncNow",
          "when": "view == remoteBridge.connections && config.remoteBridge.security.syncConnections",
          "group": "overflow@3"
        },
        {
          "command": "remoteBridge.setMasterPassword",
          "when": "view == remoteBridge.connections && !remoteBridge.encryptionEnabled",
          "group": "overflow@4"
        },
        {
          "command": "remoteBridge.changeMasterPassword",
          "when": "view == remoteBridge.connections && remoteBridge.encryptionEnabled",
          "group": "overflow@4"
        },
        {
          "command": "remoteBridge.lockMasterPassword",
          "when": "view == remoteBridge.connections && remoteBridge.encryptionEnabled && remoteBridge.encryptionUnlocked",
          "group": "overflow@5"
        },
        {
          "command": "remoteBridge.removeMasterPassword",
          "when": "view == remoteBridge.connections && remoteBridge.encryptionEnabled",
          "group": "overflow@6"
        },
        {
          "command": "remoteBridge.restoreBackup",
          "when": "view == remoteBridge.connections",
          "group": "overflow@6"
        },
        {
          "command": "remoteBridge.createBackup",
          "when": "view == remoteBridge.connections",
          "group": "overflow@7"
        }
      ],
      "view/item/context": [
        {
          "command": "remoteBridge.connect",
          "when": "view == remoteBridge.connections && viewItem =~ /^connection\\..+\\.disconnected$/",
          "group": "inline@1"
        },
        {
          "command": "remoteBridge.disconnect",
          "when": "view == remoteBridge.connections && viewItem =~ /^connection\\..+\\.connected$/",
          "group": "inline@1"
        },
        {
          "command": "remoteBridge.openTerminal",
          "when": "view == remoteBridge.connections && viewItem =~ /^connection\\.(ssh|sftp)\\.connected$/ && !listMultiSelection",
          "group": "inline@2"
        },
        {
          "command": "remoteBridge.editConnection",
          "when": "view == remoteBridge.connections && viewItem =~ /^connection\\..+/ && !listMultiSelection",
          "group": "1_manage@1"
        },
        {
          "command": "remoteBridge.duplicateConnection",
          "when": "view == remoteBridge.connections && viewItem =~ /^connection\\..+/ && !listMultiSelection",
          "group": "1_manage@2"
        },
        {
          "command": "remoteBridge.moveToFolder",
          "when": "view == remoteBridge.connections && viewItem =~ /^connection\\..+/",
          "group": "1_manage@3"
        },
        {
          "command": "remoteBridge.deleteConnection",
          "when": "view == remoteBridge.connections && viewItem =~ /^connection\\..+/",
          "group": "1_manage@4"
        },
        {
          "command": "remoteBridge.renameFolder",
          "when": "view == remoteBridge.connections && viewItem == folder",
          "group": "1_manage@1"
        },
        {
          "command": "remoteBridge.deleteFolder",
          "when": "view == remoteBridge.connections && viewItem == folder",
          "group": "1_manage@2"
        }
      ],
      "explorer/context": [
        {
          "command": "remoteBridge.changePermissions",
          "when": "resourceScheme == remote-bridge",
          "group": "2_workspace@99"
        }
      ],
      "commandPalette": [
        {
          "command": "remoteBridge.changePermissions",
          "when": "resourceScheme == remote-bridge"
        },
        {
          "command": "remoteBridge.openTerminal",
          "when": "false"
        },
        {
          "command": "remoteBridge.connect",
          "when": "false"
        },
        {
          "command": "remoteBridge.disconnect",
          "when": "false"
        },
        {
          "command": "remoteBridge.editConnection",
          "when": "false"
        },
        {
          "command": "remoteBridge.deleteConnection",
          "when": "false"
        },
        {
          "command": "remoteBridge.duplicateConnection",
          "when": "false"
        },
        {
          "command": "remoteBridge.moveToFolder",
          "when": "false"
        },
        {
          "command": "remoteBridge.openWorkspace",
          "when": "false"
        },
        {
          "command": "remoteBridge.renameFolder",
          "when": "false"
        },
        {
          "command": "remoteBridge.deleteFolder",
          "when": "false"
        },
        {
          "command": "remoteBridge.importFileZilla",
          "when": "false"
        },
        {
          "command": "remoteBridge.importPuTTY",
          "when": "false"
        },
        {
          "command": "remoteBridge.importTotalCmd",
          "when": "false"
        },
        {
          "command": "remoteBridge.unlockMasterPassword",
          "when": "remoteBridge.encryptionEnabled && !remoteBridge.encryptionUnlocked"
        },
        {
          "command": "remoteBridge.lockMasterPassword",
          "when": "remoteBridge.encryptionEnabled && remoteBridge.encryptionUnlocked"
        },
        {
          "command": "remoteBridge.changeMasterPassword",
          "when": "remoteBridge.encryptionEnabled"
        }
      ]
    },
    "submenus": [
      {
        "id": "remoteBridge.importSubmenu",
        "label": "%submenu.import.label%"
      }
    ],
    "configuration": {
      "title": "Remote Bridge",
      "properties": {
        "remoteBridge.cache.ttl": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 600,
          "description": "%config.cache.ttl.description%"
        },
        "remoteBridge.cache.maxSize": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 100,
          "description": "%config.cache.maxSize.description%"
        },
        "remoteBridge.pool.idleTimeout": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 120,
          "description": "%config.pool.idleTimeout.description%"
        },
        "remoteBridge.pool.maxConnections": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "%config.pool.maxConnections.description%"
        },
        "remoteBridge.security.syncConnections": {
          "type": "boolean",
          "default": false,
          "description": "%config.security.syncConnections.description%"
        },
        "remoteBridge.watch.pollInterval": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "%config.watch.pollInterval.description%"
        },
        "remoteBridge.files.temporaryWritePermission": {
          "type": "boolean",
          "default": false,
          "description": "%config.files.temporaryWritePermission.description%"
        },
        "remoteBridge.debug": {
          "type": "boolean",
          "default": false,
          "description": "%config.debug.description%"
        }
      }
    },
    "chatParticipants": [
      {
        "id": "remote-bridge.bridge",
        "name": "bridge",
        "fullName": "Remote Bridge",
        "description": "%chat.participant.description%",
        "isSticky": false,
        "commands": [
          {
            "name": "connect",
            "description": "%chat.command.connect.description%"
          },
          {
            "name": "ls",
            "description": "%chat.command.ls.description%"
          },
          {
            "name": "status",
            "description": "%chat.command.status.description%"
          }
        ],
        "disambiguation": [
          {
            "category": "remote-files",
            "description": "The user wants to access or manage remote files via SSH, FTP, or SFTP. All file operations (list, read, write, delete, mkdir, search) work on all protocols.",
            "examples": [
              "Show me the files on my remote server",
              "Connect to my SSH server and list files",
              "Read a file from the SFTP server"
            ]
          }
        ]
      }
    ],
    "chatSkills": [
      {
        "path": "./skills/remote-bridge/SKILL.md"
      }
    ],
    "languageModelTools": [
      {
        "name": "remote-bridge_readFile",
        "displayName": "%tool.readFile.displayName%",
        "modelDescription": "IMPORTANT: Use this tool ONLY for reading files on remote servers (connected via Remote Bridge). Do NOT use for local files or VS Code internal files — use native VS Code tools for those. When the workspace contains remote-bridge:// files, use this tool — it runs server-side (SSH) and is much faster than the filesystem provider. The `path` parameter must be an absolute server path (e.g. /www/mysite/file.php), NOT a remote-bridge:// URI. In default mode, paths outside the workspace root are rejected; in Full SSH Access mode (per-connection Advanced setting), any path on the server is allowed.\n\nIn default mode: NEVER use runCommand with grep, cat, head, tail, or sed to read or search files — this tool covers all those use cases natively. In Full SSH Access mode: runCommand with read commands is also allowed.\n\nReads the content of a file on a remote server. Supports four modes:\n\n**Search within file (PREFERRED for large files):** Provide `search` to find all occurrences of a text/regex pattern within the file. This REPLACES grep — do NOT run grep via runCommand. Supports full regex including alternation (e.g. search: 'img|overflow|max-width'). Returns matching lines with line numbers and optional context lines around each match. Use `maxResults` to limit output (default: 50). On SSH, runs grep server-side — only matches are transferred, not the whole file.\n\n**Line range:** Provide `startLine` and/or `endLine` for partial reading. On SSH only the requested lines are transferred.\n\n**Tail (last N lines):** Provide `tail` to read the last N lines. Useful for logs, appending context, or seeing end of file. On SSH uses tail server-side.\n\n**Full read:** Provide only `path` to read the entire file. Files over 2000 lines are automatically truncated to the first 200 lines. To force reading the entire file without truncation, set `startLine: 1` (without `endLine`). Prefer search mode for large files when looking for specific content.\n\nAll modes return line numbers and total line count to help plan further reads or writes.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "remoteRead",
        "icon": "$(file-code)",
        "userDescription": "%tool.readFile.userDescription%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "connectionName": {
              "type": "string",
              "description": "Connection name. Auto-detected when only one connection is active."
            },
            "path": {
              "type": "string",
              "description": "The absolute remote file path to read (e.g. /www/mysite/file.php). Do NOT include the remote-bridge:// URI prefix. Must be within the workspace root."
            },
            "startLine": {
              "type": "number",
              "description": "Optional 1-based start line for partial reading. Cannot be combined with search or tail."
            },
            "endLine": {
              "type": "number",
              "description": "Optional 1-based end line for partial reading (inclusive). Cannot be combined with search or tail."
            },
            "search": {
              "type": "string",
              "description": "Text or regex pattern to search for within the file (replaces grep — NEVER use runCommand with grep). Supports full regex syntax including alternation (e.g. 'img|image|overflow|max-width'). Returns only matching lines with line numbers and context. Use this to navigate large files efficiently instead of reading the whole file. Cannot be combined with startLine/endLine or tail."
            },
            "contextLines": {
              "type": "number",
              "description": "Number of context lines to show around each search match. Default: 3. Only used with search."
            },
            "maxResults": {
              "type": "number",
              "description": "Maximum number of matches to return in search mode. Default: 50. Only used with search."
            },
            "tail": {
              "type": "number",
              "description": "Read the last N lines of the file. Useful for logs or seeing end of file. Cannot be combined with startLine/endLine or search."
            }
          },
          "required": [
            "path"
          ]
        }
      },
      {
        "name": "remote-bridge_searchFiles",
        "displayName": "%tool.searchFiles.displayName%",
        "modelDescription": "IMPORTANT: Use this tool ONLY for searching files on remote servers (connected via Remote Bridge). Do NOT use for local files — use native search tools for those. When searching remote-bridge:// workspace files, use this tool — it runs grep/find server-side and is much faster than client-side search. The `path` parameter must be an absolute server path (e.g. /www/mysite), NOT a remote-bridge:// URI. In default mode, paths outside the workspace root are rejected; in Full SSH Access mode (per-connection Advanced setting), any path on the server is allowed.\n\nUnified search tool for remote servers. Works on all protocols (SSH, SFTP, FTP, FTPS).\n\nTwo modes — use EXACTLY ONE:\n\n**Content search** (set `pattern`, optionally `namePattern` to filter file types):\nSearches file contents using grep (SSH/SFTP) or local scan (FTP). Returns `path:line:content`. Supports regex, context lines, case sensitivity.\nExample: find all uses of \"totp\" in .js files → pattern=\"totp\", namePattern=\"*.js\"\nMulti-pattern: use regex alternation → pattern=\"class1|class2|class3\"\nTo search a single known file: set `path` to its parent directory and `namePattern` to the exact filename (e.g. path=\"/www/mysite/css\", namePattern=\"mobile.css\", pattern=\"shipping\").\n\n**File name search** (set `namePattern` only, no `pattern`):\nFinds files/directories by name glob. Returns matching paths. Supports type filter and excludePattern.\nExample: find all PHP files → namePattern=\"*.php\"\n\n`excludePattern`: excludes matching directory names in both modes (e.g. excludePattern=\"2026\" skips the 2026 folder).\n\nTo search within a SINGLE already-known file, use readFile with `search` instead.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "remoteSearch",
        "icon": "$(search)",
        "userDescription": "%tool.searchFiles.userDescription%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "connectionName": {
              "type": "string",
              "description": "Connection name. Auto-detected when only one connection is active."
            },
            "path": {
              "type": "string",
              "description": "The remote directory path to search in (e.g. /www/mysite). Do NOT include the remote-bridge:// URI prefix. Must be within the workspace root. Do NOT use '/' or parent directories above the workspace root."
            },
            "pattern": {
              "type": "string",
              "description": "Content search: the text or regex pattern to search for inside files. Omit when doing file name search."
            },
            "namePattern": {
              "type": "string",
              "description": "Glob pattern for file names (e.g. '*.php', 'config*', '*.ts'). In content search mode: filters which files are searched (like grep --include). In file name search mode (no `pattern`): finds files/directories by name."
            },
            "contextLines": {
              "type": "number",
              "description": "(Content search only) Lines of context to show before and after each match. Default: 0."
            },
            "maxResults": {
              "type": "number",
              "description": "Maximum results to return. Default: 100 (content search) or 50 (file name search)."
            },
            "caseSensitive": {
              "type": "boolean",
              "description": "(Content search only) Whether the search is case-sensitive. Default: false."
            },
            "type": {
              "type": "string",
              "enum": [
                "file",
                "directory",
                "any"
              ],
              "description": "(File name search only) Filter results by type. Default: 'any'."
            },
            "excludePattern": {
              "type": "string",
              "description": "Glob pattern to exclude from results. Works in both modes: in content search it excludes directories (e.g. 'node_modules', '2026'); in file name search it excludes matching paths."
            }
          },
          "required": [
            "path"
          ]
        }
      },
      {
        "name": "remote-bridge_runCommand",
        "displayName": "%tool.runCommand.displayName%",
        "modelDescription": "Executes a shell command on a remote server via SSH. Returns stdout and stderr. Only for SSH/SFTP connections. Prefer remoteRead/remoteSearch for file reading and searching when possible. For other tasks (builds, tests, service management, package management, diagnostics, file modifications): use this tool. Command restrictions are enforced at runtime by the extension — if a command is not allowed on this connection, the result will contain guidance on the correct approach instead of executing. Do not self-limit based on assumptions about the connection mode; just invoke the command and the extension will handle permissions. Destructive commands (halt, shutdown, reboot, rm -rf /, mkfs, dd, iptables -F) are always blocked.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "remoteRun",
        "icon": "$(terminal)",
        "userDescription": "%tool.runCommand.userDescription%",
        "inputSchema": {
          "type": "object",
          "properties": {
            "connectionName": {
              "type": "string",
              "description": "Connection name. Auto-detected when only one connection is active."
            },
            "command": {
              "type": "string",
              "description": "The shell command to execute on the remote server."
            }
          },
          "required": [
            "command"
          ]
        }
      }
    ],
    "walkthroughs": [
      {
        "id": "remoteBridge.getStarted",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "steps": [
          {
            "id": "addConnection",
            "title": "%walkthrough.step.addConnection.title%",
            "description": "%walkthrough.step.addConnection.description%",
            "media": {
              "markdown": "%walkthrough.step.addConnection.media%"
            },
            "completionEvents": [
              "onCommand:remoteBridge.addConnection"
            ]
          },
          {
            "id": "masterPassword",
            "title": "%walkthrough.step.masterPassword.title%",
            "description": "%walkthrough.step.masterPassword.description%",
            "media": {
              "markdown": "%walkthrough.step.masterPassword.media%"
            },
            "completionEvents": [
              "onCommand:remoteBridge.setMasterPassword"
            ]
          },
          {
            "id": "syncDevices",
